# ── Local Development ──
DATABASE_URL=file:./db/custom.db

# ── Auth Passwords ──
ADMIN_PASSWORD=your_admin_password_here
CREW_PASSWORD=your_crew_password_here

# ── Turso Cloud Database (for Vercel deployment) ──
# Get URL from your Turso dashboard
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# Auth token is optional on Turso free plan
# TURSO_AUTH_TOKEN=